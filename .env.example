# ─────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────
POSTGRES_DB=smartclass
POSTGRES_USER=
POSTGRES_PASSWORD=

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_PASSWORD=

# ─────────────────────────────────────────
# Backend
# ─────────────────────────────────────────
DEBUG=False
SECRET_KEY=
ALLOWED_HOSTS=localhost,127.0.0.1

# ─────────────────────────────────────────
# Frontend
# ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ─────────────────────────────────────────
# Email Alerts
# ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# ─────────────────────────────────────────
# CV Worker
# ─────────────────────────────────────────
ENABLE_ABSENCE_DETECTION=true
ENABLE_ATTENTION_TRACKER=true
ATTENTION_INTERVAL_SECONDS=5